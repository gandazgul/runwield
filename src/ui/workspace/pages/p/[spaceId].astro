---
import ReviewLayout from "../../layouts/ReviewLayout.astro";
import { RemotePlanReview } from "../../react/RemotePlanReview.tsx";
import { isRemoteDevelopmentModeEnabled } from "../../server/remote-mode.js";

const runtime = globalThis as any;
if (
    import.meta.env.DEV &&
    !isRemoteDevelopmentModeEnabled({
        isDevelopment: import.meta.env.DEV,
        workspaceMode: runtime.Deno?.env?.get?.("RUNWIELD_WORKSPACE_MODE"),
    })
) {
    return new Response("Not found", { status: 404 });
}

const spaceId = Astro.params.spaceId ?? "";
---
<ReviewLayout title="Remote Plan Review · RunWield Workspace">
    <RemotePlanReview spaceId={spaceId} client:only="react" />
</ReviewLayout>
