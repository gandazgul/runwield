# Build a clean first-run / new-user UX image through the checked-in installer.
#
# This image intentionally installs the latest published RunWield release and
# runtime helpers via ./install.sh. It validates real onboarding, not uncompiled
# source changes from this checkout.
#
# Build:
#   podman build --build-arg WLD_INSTALL_REFRESH=$(date +%s) -f Containerfile.wld-ux -t runwield-wld-ux:local .
#
# Start wld in a fresh disposable project:
#   podman run --rm -it \
#     -e ANTHROPIC_API_KEY \
#     -e OPENAI_API_KEY \
#     runwield-wld-ux:local
#
# Test against a host checkout while keeping container HOME clean:
#   podman run --rm -it \
#     -v "$PWD:/workspace/project:Z" \
#     -w /workspace/project \
#     -e ANTHROPIC_API_KEY \
#     runwield-wld-ux:local
#
# Preserve first-run state across restarts:
#   podman volume create runwield-wld-home
#   podman run --rm -it \
#     -v runwield-wld-home:/home/deno/.wld:Z \
#     runwield-wld-ux:local

FROM denoland/deno:2.9.3

USER root
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        git \
        gzip \
        less \
        libsqlite3-0 \
        openssh-client \
        tar \
    && rm -rf /var/lib/apt/lists/*

ENV HOME=/home/deno \
    WLD_INSTALL_DIR=/home/deno/.local/bin \
    PATH=/home/deno/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
    WLD_NEW_USER_UX_CONTAINER=1 \
    WLD_NONINTERACTIVE=1 \
    NO_COLOR=0

RUN mkdir -p /workspace/project /home/deno/.wld /home/deno/.local/bin \
    && chown -R deno:deno /workspace /home/deno

COPY --chown=deno:deno install.sh /tmp/install.sh

USER deno
WORKDIR /workspace/project

ARG WLD_INSTALL_REFRESH=manual
RUN echo "[wld-ux] install refresh: ${WLD_INSTALL_REFRESH}" \
    && bash /tmp/install.sh \
    && command -v wld mnemosyne cymbal snip \
    && wld --version \
    && mnemosyne version \
    && cymbal version \
    && snip --version

VOLUME ["/workspace/project", "/home/deno/.wld"]

ENTRYPOINT ["wld"]
