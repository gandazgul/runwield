#!/bin/sh
# Pre-commit hook: format staged files with deno fmt, then re-stage them.
# Install: git config core.hooksPath .githooks

set -e

staged=$(git diff --cached --name-only --diff-filter=ACM -- \
    '*.js' '*.jsx' '*.ts' '*.tsx' '*.json' '*.md' '*.css' '*.html' '*.yml' '*.yaml' | head -c 20000)

if [ -z "$staged" ]; then
    echo "  (no formattable files staged, skipping deno fmt)"
    exit 0
fi

echo "→ Running deno fmt on staged files..."
echo "$staged" | tr '\n' '\0' | xargs -0 deno fmt --quiet 2>&1
echo "$staged" | tr '\n' '\0' | xargs -0 git add
